# AI Food Passport Backend — Environment Variable Exemplar
#
# Copy this file to backend/.env and fill in real values before deploying.
# DO NOT commit backend/.env to version control.
#
# All variables below are placeholders only.
# No real API keys, secrets, or production URLs should appear here.

# --------------------------------------------------------------------------
# Runtime Deployment Config (Phase 11B skeleton)
# --------------------------------------------------------------------------

# Node environment: 'development' | 'production' | 'test'
# Default: 'development'
NODE_ENV=development

# Server port. Default: 8787
PORT=8787

# Server bind address.
# Development default: 127.0.0.1 (localhost only)
# Production default: 0.0.0.0 (all interfaces)
# Override with care.
HOST=127.0.0.1

# CORS allowed origins (comma-separated).
# Development default: local Flutter/web origins
# Production: MUST be set to your Flutter app's deployed origin(s).
# Example: ALLOWED_ORIGINS=https://your-app.web.app,https://your-app.firebaseapp.com
ALLOWED_ORIGINS=http://localhost:8787,http://localhost:3000,http://127.0.0.1:8787

# Publicly accessible backend URL for Flutter to call.
# Must be set in production (e.g. https://api.yourdomain.com).
# Development default: '' (Flutter calls localhost directly)
PUBLIC_BACKEND_URL=

# Max request body size in bytes. Default: 1048576 (1 MB)
REQUEST_BODY_LIMIT=1048576

# --------------------------------------------------------------------------
# Provider Config (skeleton — all real providers disabled by default)
# --------------------------------------------------------------------------

# OCR provider: 'mock_ocr' | 'qwen_ocr' | 'google_vision' | 'openai_vision'
# Default: 'mock_ocr'
OCR_PROVIDER=mock_ocr

# Analysis provider: 'mock_ai' | 'qwen_analysis' | 'deepseek_analysis' | 'openai_analysis'
# Default: 'mock_ai'
ANALYSIS_PROVIDER=mock_ai

# Provider routing mode: 'mock' | 'china' | 'global' | 'auto'
# Non-mock modes safely resolve to mock with fallback metadata.
# Default: 'mock'
PROVIDER_MODE=mock

# --------------------------------------------------------------------------
# Provider Safety Config (skeleton — not enforced yet)
# --------------------------------------------------------------------------

# Provider call timeout in milliseconds. Default: 30000
PROVIDER_TIMEOUT_MS=30000

# Max retries per provider call. Default: 0 (no retries)
PROVIDER_MAX_RETRIES=0

# Monthly budget cap in USD. Default: '' (not enforced)
PROVIDER_MONTHLY_BUDGET=

# Daily request limit per provider. Default: '' (not enforced)
PROVIDER_DAILY_REQUEST_LIMIT=

# --------------------------------------------------------------------------
# Secrets (DO NOT PUT REAL KEYS HERE — use deployment environment variables)
# --------------------------------------------------------------------------

# Placeholder only — do not use in code.
# QWEN_API_KEY=
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_VISION_API_KEY=
